data['team_won_toss'] = (
    data['team'] == data['toss_winner']
).astype(int)


data


data = data.drop(columns=['toss_winner'])


data = data.drop(columns=['city'])


from sklearn.preprocessing import LabelEncoder

le_player = LabelEncoder()
