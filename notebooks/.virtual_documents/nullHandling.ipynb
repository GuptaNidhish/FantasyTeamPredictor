le_venue = LabelEncoder()
data['venue'] = le_venue.fit_transform(data['venue'])
data.head()


cat_cols = [
    'team',
    'opponent',
    'toss_decision',
    'stage',
    'pitch_type',
    'player_role'
]

data = pd.get_dummies(
    data,
    columns=cat_cols,
    drop_first=True
)


data


